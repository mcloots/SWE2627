#####################################
# ITF Pulse — Root .gitignore
# Angular + .NET + Tailwind + Env
#####################################


#####################################
# ENV FILES (VERY IMPORTANT)
#####################################

.env
.env.*
!.env.example


#####################################
# NODE / ANGULAR
#####################################

node_modules/
dist/
.tmp/
.cache/
.angular/
coverage/
*.tsbuildinfo

# Angular build output
frontend/dist/
frontend/.angular/
frontend/node_modules/


#####################################
# .NET / ASP.NET
#####################################

bin/
obj/
out/
logs/

# Rider / VS
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Publish output
publish/


#####################################
# TEST OUTPUT
#####################################

TestResults/
coverage/
*.coverage
*.coveragexml


#####################################
# PACKAGE MANAGERS
#####################################

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


#####################################
# IDE FILES
#####################################

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains
.idea/

# Visual Studio
*.csproj.user


#####################################
# OS FILES
#####################################

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini


#####################################
# LOG FILES
#####################################

*.log


#####################################
# TEMP FILES
#####################################

*.tmp
*.temp
*.swp
*.bak


#####################################
# DOCKER (if later used)
#####################################

docker-compose.override.yml


#####################################
# OPTIONAL — DATABASE FILES
#####################################

*.db
*.sqlite
*.sqlite3


#####################################
# OPTIONAL — LOCAL STORAGE
#####################################

uploads/
storage/